{
  "name": "quiz-render-server",
  "version": "1.0.0",
  "description": "Video rendering server for OX Quiz using Puppeteer and FFmpeg",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "render": "tsx src/cli.ts"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "fluent-ffmpeg": "^2.1.3",
    "fs-extra": "^11.2.0",
    "glob": "^11.0.0",
    "msedge-tts": "^2.0.4",
    "p-queue": "^8.0.1",
    "puppeteer": "^23.0.0",
    "socket.io": "^4.8.0",
    "tmp": "^0.2.3",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/fluent-ffmpeg": "^2.1.26",
    "@types/fs-extra": "^11.0.4",
    "@types/tmp": "^0.2.6",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
